# ─────────────────────────────────────────────────────────────
# PageFlow — VPS Environment Variables
# Copy this file to .env and fill in every value.
# ─────────────────────────────────────────────────────────────

# PostgreSQL password (choose a strong password)
DB_PASSWORD=change_me_strong_password

# Full public URL of your site (no trailing slash)
# Used by the scheduler when generating Facebook post URLs
PUBLIC_BASE_URL=https://yourdomain.com

# JWT signing secret — generate with: openssl rand -hex 64
JWT_SECRET=change_me_jwt_secret

# Session signing secret — generate with: openssl rand -hex 64
SESSION_SECRET=change_me_session_secret

# Host port for the web container (default 80)
HOST_PORT=80

# ─── Optional / Facebook integration ──────────────────────────
# Your Facebook App credentials (from developers.facebook.com)
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
