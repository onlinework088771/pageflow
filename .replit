modules = ["nodejs-20", "web", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd /home/runner/workspace && NODE_ENV=production PORT=8080 pnpm --filter @workspace/api-server run start"]
build = ["bash", "-c", "pnpm install --frozen-lockfile && pnpm -r --if-present run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "DB: Apply Schema"

[[workflows.workflow]]
name = "DB: Apply Schema"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd lib/db && pnpm run push"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 5000

[[ports]]
localPort = 24102
externalPort = 3000

[[ports]]
localPort = 24103
externalPort = 4200

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
AUTO_DELETE = "true"
DELETE_AFTER_HOURS = "48"
API_PORT = "8080"
PUBLIC_BASE_URL = "https://af1297dc-9316-4996-b54c-6d84644e350b-00-wrla9e74405v.worf.replit.dev"
